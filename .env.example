# MediCare Hub — environment variable template
# Copy to backend/.env and fill in real values locally. Never commit .env files.

# Django
DJANGO_SETTINGS_MODULE=medicare_hub.settings.development
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite used in development; PostgreSQL optional for production)
DB_NAME=medicare_hub
DB_USER=username
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Redis & Celery (optional in development)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# CORS / URLs
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
DEFAULT_FROM_EMAIL=noreply@example.com

# Email
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
SENDGRID_API_KEY=

# SMS / WhatsApp (optional)
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=
WHATSAPP_API_TOKEN=

# Payment gateways (optional)
MPESA_API_KEY=
MPESA_PUBLIC_KEY=
SELCOM_API_KEY=
SELCOM_API_SECRET=
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# AWS S3 (production only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-west-1

# Frontend (copy to frontend/.env if needed)
# VITE_API_BASE_URL=/api/v1
