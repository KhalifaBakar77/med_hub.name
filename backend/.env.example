# Django settings module (development | production | testing)
DJANGO_SETTINGS_MODULE=medicare_hub.settings.development

# Security — generate a unique key for each environment
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web

# PostgreSQL
DB_NAME=medicare_hub
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# CORS — React frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
DEFAULT_FROM_EMAIL=noreply@medicarehub.co.tz

# Notifications — SendGrid (email)
SENDGRID_API_KEY=

# Notifications — Africa's Talking (SMS, Tanzania)
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_SHORTCODE=

# Notifications — WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

# M-Pesa Tanzania (Vodacom)
MPESA_API_KEY=
MPESA_PUBLIC_KEY=
MPESA_SERVICE_PROVIDER_CODE=
MPESA_INITIATOR_IDENTIFIER=
MPESA_SECURITY_CREDENTIAL=
MPESA_BASE_URL=https://openapi.m-pesa.com
MPESA_WEBHOOK_ALLOWED_IPS=

# Selcom API v3
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_VENDOR_ID=
SELCOM_BASE_URL=https://apigw.selcommobile.com/v1

# Airtel Money
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_MERCHANT_PIN=
AIRTEL_BASE_URL=https://openapiuat.airtel.africa
AIRTEL_COUNTRY=TZ
AIRTEL_CURRENCY=TZS
AIRTEL_WEBHOOK_SECRET=

# JWT lifetimes
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Logging
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
CELERY_LOG_LEVEL=INFO

# AWS S3 (production only — required when DJANGO_SETTINGS_MODULE=medicare_hub.settings.production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-west-1
AWS_S3_CUSTOM_DOMAIN=

# Production security (production only)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Testing
TEST_DB_NAME=test_medicare_hub
